# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ── Secrets — NEVER commit ───────────────────────────────────────────────────
.env
.env.local
.env.production
**/.env
**/.env.local
**/.env.production

# ── Build output ─────────────────────────────────────────────────────────────
dist/
tmp/
out-tsc/
*.tsbuildinfo
.expo/
.expo-shared/

# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ── Large binary / archive files ─────────────────────────────────────────────
# If you need to store binaries, use GitHub Release Assets instead.
*.zip
*.tar.gz
*.tar.bz2
*.rar
*.7z
# Catch any filename-only archive (no extension pattern like ziO9p1g1)
# Rule: files > 50MB should NEVER be committed to git.

# ── Test coverage ────────────────────────────────────────────────────────────
coverage/

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDEs ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace

# ── Replit ───────────────────────────────────────────────────────────────────
.cache/
.local/

# ── Misc ─────────────────────────────────────────────────────────────────────
/.sass-cache
npm-debug.log
yarn-error.log
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# ── Migration / accidental large-file backups ────────────────────────────────
.migration-backup/
**/.migration-backup/
ziO9p1g1
