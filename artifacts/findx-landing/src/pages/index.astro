---
import Base from "../layouts/Base.astro";

const APP_URL = "https://find-x-agents-findx.vercel.app";
---

<Base
  title="FindX — AI-powered B2B Prospecting. Find your next client, automatically."
  description="FindX uses AI to discover, analyze, and reach out to high-probability B2B leads. 3-stage AI pipeline: Discover → Analyze → Outreach. Start free. 8 countries supported."
  canonical="https://findx.nl"
>

  <!-- ══ NAVIGATION — Precision Dark ══════════════════════════════════════ -->
  <nav class="sticky top-0 z-50 h-14 flex items-center justify-between px-6 md:px-12"
       style="background: rgba(12,12,14,0.92); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); border-bottom: 1px solid var(--glass-border);">
    <a href="/" class="flex items-center gap-2.5 group" aria-label="FindX Home">
      <!-- Radar brand icon — Indigo -->
      <div class="w-7 h-7 rounded-md flex items-center justify-center transition-all group-hover:shadow-[0_0_0_1px_rgba(99,102,241,0.5)]"
           style="background: var(--primary);">
        <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" style="color:white" aria-hidden="true">
          <circle cx="12" cy="12" r="9.5" stroke="currentColor" stroke-width="1.4" stroke-opacity="0.35"/>
          <circle cx="12" cy="12" r="6"   stroke="currentColor" stroke-width="1.4" stroke-opacity="0.55"/>
          <circle cx="12" cy="12" r="2.5" stroke="currentColor" stroke-width="1.4" stroke-opacity="0.75"/>
          <circle cx="12" cy="12" r="1.2" fill="currentColor"/>
          <line x1="12" y1="12" x2="19.8" y2="5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          <circle cx="19.8" cy="5.5" r="1.1" fill="currentColor"/>
        </svg>
      </div>
      <span class="font-semibold text-sm tracking-tight" style="color: var(--text);">FindX</span>
    </a>

    <div class="flex items-center gap-1">
      <a href="/pricing"
         class="hidden md:inline-flex items-center px-3 h-8 rounded-md text-sm font-medium transition-colors hover:bg-[var(--bg-inset)]"
         style="color: var(--text-muted);">
        Pricing
      </a>
      <a href={`${APP_URL}/login`}
         class="hidden md:inline-flex items-center px-3 h-8 rounded-md text-sm font-medium transition-colors"
         style="color: var(--text-muted);">
        Sign in
      </a>
      <a href={`${APP_URL}/login`}
         class="inline-flex items-center gap-1.5 px-3 h-8 rounded-md text-sm font-semibold transition-all hover:opacity-90"
         style="background: var(--primary); color: white;">
        Get started
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </nav>

  <!-- ══ HERO — Precision Dark ═════════════════════════════════════════════ -->
  <section class="relative overflow-hidden pt-24 pb-32 px-6">
    <!-- Single subtle Indigo glow at top — no mesh spam -->
    <div class="pointer-events-none absolute top-0 left-1/2 -translate-x-1/2 w-[500px] h-[200px] rounded-full"
         style="background: radial-gradient(ellipse, rgba(99,102,241,0.12) 0%, transparent 70%); filter: blur(40px);" aria-hidden="true"></div>

    <div class="relative max-w-4xl mx-auto text-center">

      <!-- ─ Editorial badge (open-design.ai micro-typography) ──────────── -->
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold tracking-wider mb-10"
           style="background: rgba(99,102,241,0.10); color: var(--primary); border: 1px solid rgba(99,102,241,0.20);">
        <!-- 01 — section number, editorial detail -->
        <span class="section-number" style="color: inherit; opacity: 0.7;">01</span>
        <span class="relative flex h-1.5 w-1.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-60" style="background: var(--primary);"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5" style="background: var(--primary);"></span>
        </span>
        AI-powered B2B Prospecting
      </div>

      <!-- ─ Headline — Inter, tight tracking ───────────────────────────── -->
      <h1 class="text-5xl md:text-[4.5rem] font-bold tracking-[-0.04em] leading-[1.05] mb-6 text-balance">
        Find your next client,<br />
        <span style="color: var(--primary);">automatically.</span>
      </h1>

      <!-- ─ Sub ────────────────────────────────────────────────────────── -->
      <p class="text-lg md:text-xl leading-relaxed mb-10 max-w-2xl mx-auto text-balance"
         style="color: var(--text-muted);">
        FindX uses AI to discover, analyze, and reach out to high-probability
        leads anywhere in the world — while you focus on closing.
      </p>

      <!-- ─ CTA row ─────────────────────────────────────────────────────── -->
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        <a href={`${APP_URL}/login`}
           class="inline-flex items-center gap-2.5 px-6 h-11 rounded-lg text-sm font-semibold text-white transition-all hover:opacity-90"
           style="background: var(--primary); box-shadow: var(--shadow-brand);">
          Get started free
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="#how"
           class="inline-flex items-center gap-2.5 px-6 h-11 rounded-lg text-sm font-semibold transition-all"
           style="background: var(--glass); border: 1px solid var(--glass-border); color: var(--text-muted);">
          See how it works
        </a>
      </div>

      <!-- ─ Trust signals — editorial metadata hints ───────────────────── -->
      <div class="flex flex-wrap justify-center gap-x-6 gap-y-2">
        {[
          "Secure Google OAuth",
          "GDPR compliant",
          "8 countries supported",
        ].map((text) => (
          <div class="flex items-center gap-1.5 meta-hint">
            <svg class="w-3 h-3 flex-shrink-0" style="color: #22C55E;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            {text}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ STATS — Precision data strip ═════════════════════════════════════ -->
  <section class="py-16 border-y" style="border-color: var(--glass-border); background: var(--bg-subtle);">
    <div class="max-w-4xl mx-auto px-6">
      <!-- Section label — editorial -->
      <p class="text-center section-label mb-10" style="color: var(--text-subtle);">
        02 — Platform metrics
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x"
           style="--tw-divide-color: var(--glass-border);">
        {[
          { value: "40+", label: "agencies using FindX",  sub: "beta, early 2025" },
          { value: "3",   label: "AI pipeline stages",    sub: "Discover → Analyze → Outreach" },
          { value: "8",   label: "countries supported",   sub: "and growing" },
        ].map(({ value, label, sub }) => (
          <div class="flex flex-col items-center py-8 px-6">
            <span class="text-4xl font-bold tracking-[-0.04em] font-mono mb-1" style="color: var(--text); font-variant-numeric: tabular-nums;">
              {value}
            </span>
            <span class="text-sm font-medium mb-1" style="color: var(--text-muted);">{label}</span>
            <span class="meta-hint">{sub}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ HOW IT WORKS — 3-step pipeline ════════════════════════════════════ -->
  <section id="how" class="py-32 px-6">
    <div class="max-w-5xl mx-auto">

      <!-- Section header — editorial numbered -->
      <div class="mb-20 max-w-xl">
        <p class="section-label mb-4">03 — How it works</p>
        <h2 class="text-4xl font-bold tracking-[-0.03em]" style="color: var(--text);">
          3 agents.<br />Full pipeline.
        </h2>
        <p class="mt-4 text-base" style="color: var(--text-muted);">
          From search to signed client — fully automated.
        </p>
      </div>

      <!-- Step 1 — Discover -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center mb-32">
        <div>
          <div class="inline-flex items-center gap-2 px-2.5 py-1 rounded text-xs font-semibold tracking-wider mb-5"
               style="color: #3B82F6; background: rgba(59,130,246,0.08); border: 1px solid rgba(59,130,246,0.18);">
            <span class="font-mono">01</span> Discover
          </div>
          <h3 class="text-2xl font-bold tracking-tight mb-4" style="color: var(--text);">Find the right leads</h3>
          <p class="text-base leading-relaxed max-w-[48ch]" style="color: var(--text-muted);">
            AI finds businesses matching your ICP from web data and global directories.
            Searches across 8 countries and dozens of sources simultaneously.
          </p>
        </div>
        <!-- Discover mockup — precision card -->
        <div class="rounded-lg p-4 space-y-2.5"
             style="background: var(--glass); border: 1px solid var(--glass-border);">
          <div class="flex items-center gap-2 rounded-md px-3 py-2"
               style="background: var(--bg-inset); border: 1px solid var(--glass-border);">
            <svg class="w-3.5 h-3.5 flex-shrink-0" style="color: var(--text-subtle);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span class="text-xs font-mono" style="color: var(--text-muted);">web design agency amsterdam</span>
          </div>
          {[
            { name: "Pixelcraft Studio",  city: "Amsterdam", score: "72", blocked: false },
            { name: "NoordCode Digital",  city: "Amsterdam", score: "58", blocked: false },
            { name: "Design Collective",  city: "Haarlem",   score: "",   blocked: true  },
          ].map(({ name, city, score, blocked }) => (
            <div class="flex items-center justify-between rounded-md px-3 py-2.5"
                 style="background: var(--bg-inset); border: 1px solid var(--glass-border);">
              <div>
                <p class="text-xs font-semibold" style="color: var(--text);">{name}</p>
                <p class="text-xs meta-hint">{city}</p>
              </div>
              {blocked
                ? <span class="text-xs font-semibold px-2 py-0.5 rounded"
                        style="background: rgba(244,63,94,0.10); color: #F43F5E; border: 1px solid rgba(244,63,94,0.18);">blocked ✗</span>
                : <span class="text-sm font-bold font-mono" style="color: #22C55E; font-variant-numeric: tabular-nums;">{score}</span>
              }
            </div>
          ))}
        </div>
      </div>

      <!-- Step 2 — Analyze -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center mb-32">
        <div class="md:order-2">
          <div class="inline-flex items-center gap-2 px-2.5 py-1 rounded text-xs font-semibold tracking-wider mb-5"
               style="color: #F59E0B; background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.18);">
            <span class="font-mono">02</span> Analyze
          </div>
          <h3 class="text-2xl font-bold tracking-tight mb-4" style="color: var(--text);">Score with precision</h3>
          <p class="text-base leading-relaxed max-w-[48ch]" style="color: var(--text-muted);">
            Gemini AI scores and ranks each lead 0–100 based on real website data,
            digital gaps, and conversion probability.
          </p>
        </div>
        <!-- Analyze mockup -->
        <div class="rounded-lg p-4 space-y-3 md:order-1"
             style="background: var(--glass); border: 1px solid var(--glass-border);">
          <div class="flex items-center justify-between pb-3"
               style="border-bottom: 1px solid var(--glass-border);">
            <div>
              <p class="text-sm font-semibold" style="color: var(--text);">Pixelcraft Studio</p>
              <p class="text-xs meta-hint">pixelcraft.nl · Amsterdam</p>
            </div>
            <div class="flex flex-col items-end">
              <span class="text-3xl font-bold font-mono" style="color: #F59E0B; font-variant-numeric: tabular-nums;">34</span>
              <span class="text-xs meta-hint">/100 score</span>
            </div>
          </div>
          <div class="space-y-1.5">
            {[
              { label: "No SSL certificate", color: "#F43F5E", bg: "rgba(244,63,94,0.08)",    border: "rgba(244,63,94,0.18)" },
              { label: "Slow load speed",     color: "#F59E0B", bg: "rgba(245,158,11,0.08)",  border: "rgba(245,158,11,0.18)" },
              { label: "No social presence",  color: "#3B82F6", bg: "rgba(59,130,246,0.08)",  border: "rgba(59,130,246,0.18)" },
            ].map(({ label, color, bg, border }) => (
              <div class="flex items-center gap-2 px-3 py-1.5 rounded text-xs font-semibold"
                   style={`background: ${bg}; color: ${color}; border: 1px solid ${border};`}>
                {label}
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Step 3 — Outreach -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-2.5 py-1 rounded text-xs font-semibold tracking-wider mb-5"
               style="color: #22C55E; background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.18);">
            <span class="font-mono">03</span> Outreach
          </div>
          <h3 class="text-2xl font-bold tracking-tight mb-4" style="color: var(--text);">Send with one click</h3>
          <p class="text-base leading-relaxed max-w-[48ch]" style="color: var(--text-muted);">
            Generate hyper-personalized emails and send them in one click.
            Every message references the lead's specific website findings.
          </p>
        </div>
        <!-- Outreach mockup -->
        <div class="rounded-lg p-4 space-y-3"
             style="background: var(--glass); border: 1px solid var(--glass-border);">
          <div class="flex items-center justify-between pb-3"
               style="border-bottom: 1px solid var(--glass-border);">
            <div>
              <p class="text-xs font-semibold" style="color: var(--text);">info@pixelcraft.nl</p>
              <p class="text-xs meta-hint">New outreach draft ready</p>
            </div>
            <span class="text-xs font-semibold px-2 py-0.5 rounded"
                  style="background: rgba(245,158,11,0.10); color: #F59E0B; border: 1px solid rgba(245,158,11,0.20);">
              Pending review
            </span>
          </div>
          <div>
            <p class="text-xs section-label mb-1" style="color: var(--text-subtle);">Subject</p>
            <p class="text-sm font-semibold" style="color: var(--text);">
              Quick win for Pixelcraft — SSL issue on your homepage
            </p>
          </div>
          <div class="rounded-md px-3 py-2.5"
               style="background: var(--bg-inset); border: 1px solid var(--glass-border);">
            <p class="text-xs leading-relaxed" style="color: var(--text-muted);">
              Hi Pixelcraft team, I noticed your site currently loads without an SSL certificate —
              something we can fix in under 24 hours and immediately boost your Google ranking…
            </p>
          </div>
          <div class="flex gap-2">
            <button class="flex-1 text-xs font-semibold py-2 rounded-md text-white"
                    style="background: var(--primary);">Approve &amp; Send</button>
            <button class="flex-1 text-xs font-semibold py-2 rounded-md"
                    style="background: var(--bg-inset); border: 1px solid var(--glass-border); color: var(--text-muted);">Edit</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ CTA SECTION — Precision ═══════════════════════════════════════════ -->
  <section class="py-32 px-6 border-t" style="border-color: var(--glass-border);">
    <div class="max-w-2xl mx-auto">
      <!-- Editorial section label -->
      <p class="section-label mb-6">04 — Get started</p>

      <h2 class="text-4xl font-bold tracking-[-0.03em] mb-4" style="color: var(--text);">
        Ready to find your<br />next client?
      </h2>
      <p class="text-base mb-8" style="color: var(--text-muted);">
        Start for free. No credit card required.
      </p>
      <div class="flex gap-3">
        <a href={`${APP_URL}/login`}
           class="inline-flex items-center gap-2 px-6 h-10 rounded-lg text-sm font-semibold text-white transition-all hover:opacity-90"
           style="background: var(--primary); box-shadow: var(--shadow-brand);">
          Get started free
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ══ FOOTER — Precision ════════════════════════════════════════════════ -->
  <footer class="py-10 border-t" style="border-color: var(--glass-border);">
    <div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-2.5">
        <div class="w-6 h-6 rounded flex items-center justify-center" style="background: var(--primary);">
          <svg viewBox="0 0 24 24" fill="none" class="w-3.5 h-3.5" style="color: white;" aria-hidden="true">
            <circle cx="12" cy="12" r="9.5" stroke="currentColor" stroke-width="1.4" stroke-opacity="0.35"/>
            <circle cx="12" cy="12" r="6"   stroke="currentColor" stroke-width="1.4" stroke-opacity="0.55"/>
            <circle cx="12" cy="12" r="2.5" stroke="currentColor" stroke-width="1.4" stroke-opacity="0.75"/>
            <circle cx="12" cy="12" r="1.2" fill="currentColor"/>
            <line x1="12" y1="12" x2="19.8" y2="5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            <circle cx="19.8" cy="5.5" r="1.1" fill="currentColor"/>
          </svg>
        </div>
        <span class="text-sm font-medium" style="color: var(--text-muted);">
          © {new Date().getFullYear()} FindX Intelligence
        </span>
      </div>
      <nav class="flex gap-6" aria-label="Footer navigation">
        {[
          { href: "/privacy", label: "Privacy" },
          { href: "/terms",   label: "Terms" },
          { href: "/pricing", label: "Pricing" },
          { href: "mailto:support@findx.nl", label: "Support" },
        ].map(({ href, label }) => (
          <a href={href}
             class="text-xs font-medium transition-colors hover:opacity-80"
             style="color: var(--text-subtle);">
            {label}
          </a>
        ))}
      </nav>
    </div>
  </footer>

</Base>
