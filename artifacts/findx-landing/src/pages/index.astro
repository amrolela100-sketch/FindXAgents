---
import Base from "../layouts/Base.astro";

const APP_URL = "https://find-x-agents-findx.vercel.app";
---

<Base
  title="FindX — AI-powered B2B Prospecting. Find your next client, automatically."
  description="FindX uses AI to discover, analyze, and reach out to high-probability B2B leads. 3-stage AI pipeline: Discover → Analyze → Outreach. Start free. 8 countries supported."
  canonical="https://findx.nl"
>

  <!-- ══ NAVIGATION ═══════════════════════════════════════════════════════ -->
  <nav class="sticky top-0 z-50 h-16 flex items-center justify-between px-6 md:px-12
              bg-[var(--glass)] backdrop-blur-xl border-b border-[var(--glass-border)]">
    <a href="/" class="flex items-center gap-2.5 group" aria-label="FindX Home">
      <!-- Radar brand icon -->
      <div class="w-8 h-8 rounded-lg flex items-center justify-center shadow-[var(--shadow-brand)] transition-transform group-hover:scale-105"
           style="background: var(--primary);">
        <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4 text-white" style="color:white" aria-hidden="true">
          <circle cx="12" cy="12" r="9.5" stroke="currentColor" stroke-width="1.4" stroke-opacity="0.35"/>
          <circle cx="12" cy="12" r="6"   stroke="currentColor" stroke-width="1.4" stroke-opacity="0.55"/>
          <circle cx="12" cy="12" r="2.5" stroke="currentColor" stroke-width="1.4" stroke-opacity="0.75"/>
          <circle cx="12" cy="12" r="1.2" fill="currentColor"/>
          <line x1="12" y1="12" x2="19.8" y2="5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          <circle cx="19.8" cy="5.5" r="1.1" fill="currentColor"/>
        </svg>
      </div>
      <span class="font-bold text-lg tracking-tight text-[var(--text)]">FindX</span>
    </a>

    <div class="flex items-center gap-3">
      <a href="/pricing" class="hidden md:inline text-sm font-semibold text-[var(--text-muted)] hover:text-[var(--text)] transition-colors">
        Pricing
      </a>
      <a href={`${APP_URL}/login`}
         class="inline-flex items-center gap-2 px-4 h-9 rounded-lg text-sm font-bold text-white transition-all hover:opacity-90"
         style="background: var(--primary); box-shadow: var(--shadow-brand);">
        Get started free
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </nav>

  <!-- ══ HERO ══════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden pt-20 pb-28 px-6">
    <!-- Background glow -->
    <div class="pointer-events-none absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full blur-[120px] opacity-20 animate-pulse"
         style="background: var(--primary);" aria-hidden="true"></div>

    <div class="relative max-w-4xl mx-auto text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest mb-8 border"
           style="background: color-mix(in srgb, var(--primary) 12%, transparent); color: var(--primary); border-color: color-mix(in srgb, var(--primary) 25%, transparent);">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75" style="background: var(--primary);"></span>
          <span class="relative inline-flex rounded-full h-2 w-2" style="background: var(--primary);"></span>
        </span>
        AI-powered B2B Prospecting
      </div>

      <!-- Language badge -->
      <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold mb-8 ml-3 border"
           style="background: var(--glass); border-color: var(--glass-border); color: var(--text-subtle);">
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
        </svg>
        Arabic · English · Dutch · French · +2 more
      </div>

      <!-- Headline -->
      <h1 class="text-5xl md:text-7xl font-bold tracking-tighter leading-[1.08] mb-8 text-balance"
          style="color: var(--text);">
        Find your next client,<br />
        <span style="color: var(--primary);">automatically.</span>
      </h1>

      <!-- Sub -->
      <p class="text-xl md:text-2xl leading-relaxed mb-12 max-w-2xl mx-auto text-balance"
         style="color: var(--text-muted);">
        FindX uses AI to discover, analyze, and reach out to high-probability
        leads anywhere in the world — while you focus on closing.
      </p>

      <!-- CTA buttons -->
      <div class="flex flex-wrap justify-center gap-4 mb-10">
        <a href={`${APP_URL}/login`}
           class="inline-flex items-center gap-3 px-8 h-14 rounded-xl text-base font-bold text-white transition-all hover:opacity-90 hover:scale-[1.02]"
           style="background: var(--primary); box-shadow: var(--shadow-brand);">
          Get started free
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="#how"
           class="inline-flex items-center gap-3 px-8 h-14 rounded-xl text-base font-bold transition-all hover:opacity-80"
           style="background: var(--glass); border: 1px solid var(--glass-border); color: var(--text);">
          See how it works
        </a>
      </div>

      <!-- Trust signals -->
      <div class="flex flex-wrap justify-center gap-x-6 gap-y-2">
        {[
          { icon: "lock",    text: "Secure Google OAuth — we never store passwords" },
          { icon: "shield",  text: "Website data encrypted at rest" },
          { icon: "globe",   text: "GDPR compliant — right to deletion" },
        ].map(({ icon, text }) => (
          <div class="flex items-center gap-1.5 text-xs uppercase tracking-wider font-semibold"
               style="color: var(--text-subtle);">
            <svg class="w-3.5 h-3.5 flex-shrink-0 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              {icon === "lock"   && <><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></>}
              {icon === "shield" && <><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></>}
              {icon === "globe"  && <><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></>}
            </svg>
            {text}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ STATS ══════════════════════════════════════════════════════════════ -->
  <section class="py-20 border-y" style="background: color-mix(in srgb, var(--glass) 30%, transparent); border-color: var(--glass-border);">
    <div class="max-w-5xl mx-auto px-6">
      <p class="text-center text-xs uppercase tracking-widest font-semibold mb-12"
         style="color: var(--text-subtle);">
        Based on beta data, early 2025
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        {[
          { value: "40+",   label: "agencies using FindX",   icon: "users" },
          { value: "3",     label: "AI pipeline stages",      icon: "trending-up" },
          { value: "8",     label: "countries supported",     icon: "globe" },
        ].map(({ value, label, icon }) => (
          <div class="flex items-center gap-6">
            <div class="w-14 h-14 rounded-2xl flex items-center justify-center flex-shrink-0"
                 style="background: var(--glass); border: 1px solid var(--glass-border);">
              <svg class="w-6 h-6" style="color: var(--primary);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                {icon === "users"       && <><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></>}
                {icon === "trending-up" && <><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></>}
                {icon === "globe"       && <><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></>}
              </svg>
            </div>
            <div>
              <div class="text-4xl font-bold tracking-tighter leading-none mb-1 font-mono" style="color: var(--text);">
                {value}
              </div>
              <div class="text-sm font-medium" style="color: var(--text-muted);">{label}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ HOW IT WORKS ══════════════════════════════════════════════════════ -->
  <section id="how" class="py-32 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="mb-24 text-center">
        <p class="text-xs font-bold uppercase tracking-[0.2em] mb-4" style="color: var(--primary);">
          How it works
        </p>
        <h2 class="text-5xl font-bold tracking-tighter" style="color: var(--text);">
          3 agents. Full pipeline.
        </h2>
      </div>

      <!-- Step 1 — Discover -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center mb-40">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider mb-6 border"
               style="color: #3B82F6; background: rgba(59,130,246,0.1); border-color: rgba(59,130,246,0.25);">
            <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span> Step 1
          </div>
          <h3 class="text-3xl font-bold tracking-tight mb-4" style="color: var(--text);">Discover</h3>
          <p class="text-base leading-relaxed max-w-[50ch]" style="color: var(--text-muted);">
            AI finds businesses matching your ICP from web data and global directories.
            Searches across 8 countries and dozens of sources simultaneously.
          </p>
        </div>
        <!-- Discover Mockup -->
        <div class="rounded-2xl p-5 space-y-3"
             style="background: var(--glass); border: 1px solid var(--glass-border); box-shadow: 0 20px 40px rgba(0,0,0,0.15);">
          <div class="flex items-center gap-2 rounded-lg px-3 py-2" style="background: rgba(0,0,0,0.06); border: 1px solid var(--glass-border);">
            <svg class="w-3.5 h-3.5 flex-shrink-0" style="color: var(--primary);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span class="text-xs font-mono truncate" style="color: var(--text-muted);">web design agency amsterdam</span>
          </div>
          {[
            { name: "Pixelcraft Studio",  city: "Amsterdam", score: "72", blocked: false },
            { name: "NoordCode Digital",  city: "Amsterdam", score: "58", blocked: false },
            { name: "Design Collective",  city: "Haarlem",   score: "",   blocked: true  },
          ].map(({ name, city, score, blocked }) => (
            <div class="flex items-center justify-between rounded-lg px-3 py-2" style="background: rgba(255,255,255,0.06); border: 1px solid var(--glass-border);">
              <div>
                <p class="text-xs font-semibold" style="color: var(--text);">{name}</p>
                <p class="text-xs" style="color: var(--text-muted);">{city}</p>
              </div>
              {blocked
                ? <span class="text-xs font-bold px-2 py-0.5 rounded-full" style="background: rgba(239,68,68,0.12); color: #EF4444; border: 1px solid rgba(239,68,68,0.25);">Directory blocked ✗</span>
                : <span class="text-sm font-bold font-mono text-green-400">{score}/100</span>
              }
            </div>
          ))}
        </div>
      </div>

      <!-- Step 2 — Analyze -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center mb-40">
        <div class="md:order-2">
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider mb-6 border"
               style="color: #F59E0B; background: rgba(245,158,11,0.1); border-color: rgba(245,158,11,0.25);">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span> Step 2
          </div>
          <h3 class="text-3xl font-bold tracking-tight mb-4" style="color: var(--text);">Analyze</h3>
          <p class="text-base leading-relaxed max-w-[50ch]" style="color: var(--text-muted);">
            Gemini AI scores and ranks each lead 0–100 based on real website data,
            digital gaps, and conversion probability.
          </p>
        </div>
        <!-- Analyze Mockup -->
        <div class="rounded-2xl p-5 space-y-4 md:order-1"
             style="background: var(--glass); border: 1px solid var(--glass-border); box-shadow: 0 20px 40px rgba(0,0,0,0.15);">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-bold" style="color: var(--text);">Pixelcraft Studio</p>
              <p class="text-xs" style="color: var(--text-muted);">pixelcraft.nl · Amsterdam</p>
            </div>
            <div class="flex flex-col items-center">
              <span class="text-3xl font-bold font-mono" style="color: #F59E0B;">34</span>
              <span class="text-xs uppercase tracking-wider" style="color: var(--text-muted);">/100</span>
            </div>
          </div>
          <div class="space-y-2">
            {[
              { label: "No SSL certificate", color: "#EF4444", bg: "rgba(239,68,68,0.1)",    border: "rgba(239,68,68,0.25)" },
              { label: "Slow load speed",     color: "#F59E0B", bg: "rgba(245,158,11,0.1)",  border: "rgba(245,158,11,0.25)" },
              { label: "No social presence",  color: "#3B82F6", bg: "rgba(59,130,246,0.1)",  border: "rgba(59,130,246,0.25)" },
            ].map(({ label, color, bg, border }) => (
              <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-semibold" style={`background: ${bg}; color: ${color}; border: 1px solid ${border};`}>
                {label} ✗
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Step 3 — Outreach -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider mb-6 border"
               style="color: #10B981; background: rgba(16,185,129,0.1); border-color: rgba(16,185,129,0.25);">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Step 3
          </div>
          <h3 class="text-3xl font-bold tracking-tight mb-4" style="color: var(--text);">Outreach</h3>
          <p class="text-base leading-relaxed max-w-[50ch]" style="color: var(--text-muted);">
            Generate hyper-personalized emails and send them in one click.
            Every message references the lead's specific website findings.
          </p>
        </div>
        <!-- Outreach Mockup -->
        <div class="rounded-2xl p-5 space-y-3"
             style="background: var(--glass); border: 1px solid var(--glass-border); box-shadow: 0 20px 40px rgba(0,0,0,0.15);">
          <div class="flex items-center gap-2 pb-2" style="border-bottom: 1px solid var(--glass-border);">
            <div class="w-6 h-6 rounded-full flex items-center justify-center" style="background: color-mix(in srgb, var(--primary) 20%, transparent);">
              <svg class="w-3 h-3" style="color: var(--primary);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div>
              <p class="text-xs font-bold" style="color: var(--text);">New outreach ready</p>
              <p class="text-xs" style="color: var(--text-muted);">To: info@pixelcraft.nl</p>
            </div>
            <span class="ml-auto text-xs font-bold px-2 py-0.5 rounded-full"
                  style="background: rgba(245,158,11,0.12); color: #F59E0B; border: 1px solid rgba(245,158,11,0.25);">
              Pending review
            </span>
          </div>
          <div>
            <p class="text-xs uppercase tracking-wider font-bold mb-1" style="color: var(--text-muted);">Subject</p>
            <p class="text-sm font-semibold" style="color: var(--text);">
              Quick win for Pixelcraft — SSL issue on your homepage
            </p>
          </div>
          <div class="rounded-lg px-3 py-2" style="background: rgba(255,255,255,0.04); border: 1px solid var(--glass-border);">
            <p class="text-xs leading-relaxed" style="color: var(--text-muted);">
              Hi Pixelcraft team, I noticed your site currently loads without an SSL certificate —
              something we can fix in under 24 hours and immediately boost your Google ranking…
            </p>
          </div>
          <div class="flex gap-2">
            <button class="flex-1 text-xs font-bold py-1.5 rounded-lg text-white" style="background: var(--primary);">Approve &amp; Send</button>
            <button class="flex-1 text-xs font-bold py-1.5 rounded-lg" style="background: var(--glass); border: 1px solid var(--glass-border); color: var(--text-muted);">Edit</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ CTA SECTION ═══════════════════════════════════════════════════════ -->
  <section class="py-32 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-4xl md:text-5xl font-bold tracking-tighter mb-6 text-balance" style="color: var(--text);">
        Ready to find your next client?
      </h2>
      <p class="text-xl mb-10" style="color: var(--text-muted);">
        Start for free. No credit card required.
      </p>
      <a href={`${APP_URL}/login`}
         class="inline-flex items-center gap-3 px-10 h-14 rounded-xl text-base font-bold text-white transition-all hover:opacity-90 hover:scale-[1.02]"
         style="background: var(--primary); box-shadow: var(--shadow-brand);">
        Get started free
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- ══ FOOTER ════════════════════════════════════════════════════════════ -->
  <footer class="py-12 border-t" style="border-color: var(--glass-border);">
    <div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg flex items-center justify-center"
             style="background: color-mix(in srgb, var(--primary) 15%, transparent); color: var(--primary);">
          <svg viewBox="0 0 24 24" fill="none" class="w-4 h-4" aria-hidden="true">
            <circle cx="12" cy="12" r="9.5" stroke="currentColor" stroke-width="1.4" stroke-opacity="0.35"/>
            <circle cx="12" cy="12" r="6"   stroke="currentColor" stroke-width="1.4" stroke-opacity="0.55"/>
            <circle cx="12" cy="12" r="2.5" stroke="currentColor" stroke-width="1.4" stroke-opacity="0.75"/>
            <circle cx="12" cy="12" r="1.2" fill="currentColor"/>
            <line x1="12" y1="12" x2="19.8" y2="5.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            <circle cx="19.8" cy="5.5" r="1.1" fill="currentColor"/>
          </svg>
        </div>
        <span class="font-bold" style="color: var(--text);">© {new Date().getFullYear()} FindX Intelligence.</span>
      </div>
      <nav class="flex gap-8" aria-label="Footer navigation">
        <a href="/privacy" class="text-xs font-bold uppercase tracking-wider transition-colors hover:opacity-80" style="color: var(--text-muted);">Privacy</a>
        <a href="/terms"   class="text-xs font-bold uppercase tracking-wider transition-colors hover:opacity-80" style="color: var(--text-muted);">Terms</a>
        <a href="/pricing" class="text-xs font-bold uppercase tracking-wider transition-colors hover:opacity-80" style="color: var(--text-muted);">Pricing</a>
        <a href="mailto:support@findx.nl" class="text-xs font-bold uppercase tracking-wider transition-colors hover:opacity-80" style="color: var(--text-muted);">Support</a>
      </nav>
    </div>
  </footer>

</Base>
