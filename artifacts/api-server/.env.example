# ─── Database Configuration (Docker & Drizzle) ────────────────────────────────
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DB_NAME"
POSTGRES_USER="findx_user"
POSTGRES_PASSWORD="CHANGE_ME"
POSTGRES_DB="findx_db"

# ─── Server & Security ─────────────────────────────────────────────────────────
PORT="3000"
FRONTEND_URL="http://localhost:80"

# ─── Supabase (required for authentication) ────────────────────────────────────
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─── Owner Access (you — highest privilege) ────────────────────────────────────
# Set these to YOUR email and a strong secondary password.
# The owner panel at /owner requires both your Supabase login AND this password.
OWNER_EMAIL="your-email@example.com"
OWNER_PASSWORD="CHANGE_ME_strong_owner_password"

# ─── Admin Access (optional team members) ──────────────────────────────────────
# Comma-separated list of emails that get access to /admin panel.
# The owner email is automatically an admin too.
ADMIN_EMAILS="your-email@example.com,colleague@example.com"

# ─── AI & Search Features ─────────────────────────────────────────────────────
OPENROUTER_API_KEY="sk-or-v1-..."
TAVILY_API_KEY="tvly-..."
GEMINI_API_KEY="AIzaSy..."

# ─── Lead Discovery (at least one recommended) ────────────────────────────────
KVK_API_KEY="..."
GOOGLE_MAPS_API_KEY="AIzaSy..."

# ─── Email Sending (optional) ─────────────────────────────────────────────────
RESEND_API_KEY="re_..."
