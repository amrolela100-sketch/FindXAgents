# ─── Database Configuration (Docker & Drizzle) ────────────────────────────────
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DB_NAME"
POSTGRES_USER="findx_user"
POSTGRES_PASSWORD="CHANGE_ME"
POSTGRES_DB="findx_db"

# ─── Server & Security ─────────────────────────────────────────────────────────
PORT="3000"
# FRONTEND_URL controls CORS allowed origins.
# ⚠️  For LOCAL DEV (pnpm dev):  use http://localhost:5173  (Vite default)
# ⚠️  For DOCKER (docker-compose): use http://localhost:80  (nginx on port 80)
# ⚠️  For PRODUCTION (Render + Vercel): paste your full Vercel URL, e.g. https://findx.vercel.app
FRONTEND_URL="http://localhost:5173"

# ─── Supabase (required for authentication) ────────────────────────────────────
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─── Owner Access (you — highest privilege) ────────────────────────────────────
OWNER_EMAIL="your-email@example.com"
OWNER_PASSWORD="CHANGE_ME_strong_owner_password"

# ─── Secret Encryption (required when saving API keys in DB) ─────────────────
# Generate with: openssl rand -base64 32
SECRET_ENCRYPTION_KEY="CHANGE_ME_generate_32_random_bytes"

# Admin access is controlled by the users.role column in the database.

# ─── AI & Search Features ─────────────────────────────────────────────────────
OPENROUTER_API_KEY="sk-or-v1-..."
TAVILY_API_KEY="tvly-..."
GEMINI_API_KEY="AIzaSy..."

# ─── Lead Discovery (at least one recommended) ────────────────────────────────
KVK_API_KEY="..."
GOOGLE_MAPS_API_KEY="AIzaSy..."

# ─── Email Sending (optional) ─────────────────────────────────────────────────
RESEND_API_KEY="re_..."


# ─── Background Jobs (optional, recommended for serverless entrypoints) ───────
# If QSTASH_TOKEN is set, /agents/run enqueues to QStash instead of running in
# the request process. JOB_WORKER_URL/PUBLIC_API_URL should point to a long-lived
# API worker endpoint that can process agent runs safely.
QSTASH_TOKEN=""
INTERNAL_JOB_SECRET="CHANGE_ME_shared_job_secret"
JOB_WORKER_URL="http://localhost:3000"

# ─── Redis (rate-limiting — shared across all instances) ──────────────────────
# Leave empty for local dev (falls back to MemoryStore automatically)
# Docker: set to redis://redis:6379
# Render: auto-populated via render.yaml fromService
REDIS_URL=""

# ─── Scrapy Deep Auditor (optional — enables deep website crawl + audit) ───────
# When running via docker-compose, this is automatically set to:
#   http://scrapy-auditor:4000
# For local dev without Docker, run the auditor separately on port 4000.
# If not set, FindX falls back to the built-in website-scraper.ts (homepage only).
SCRAPY_AUDITOR_URL="http://scrapy-auditor:4000"

# Optional shared secret between api-server and scrapy-auditor (recommended in prod)
SCRAPY_AUDITOR_SECRET=""
