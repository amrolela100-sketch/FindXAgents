{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm run build:core",
    "build:core": "pnpm run typecheck && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/findx run build",
    "build:marketing": "pnpm --filter @workspace/findx-pitch-deck run build && pnpm --filter @workspace/findx-promo run build",
    "build:mobile": "pnpm --filter @workspace/findx-mobile run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --if-present run typecheck",
    "test": "vitest run"
  },
  "private": true,
  "devDependencies": {
    "@types/supertest": "^7.2.0",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "typescript": "~5.9.2",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild",
      "@tailwindcss/oxide",
      "lightningcss",
      "rollup",
      "vite"
    ],
    "overrides": {
      "@esbuild-kit/esm-loader": "npm:tsx@^4.21.0",
